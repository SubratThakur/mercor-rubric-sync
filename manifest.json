{
  "manifest_version": 3,
  "name": "Mercor Studio — Rubric Sync",
  "version": "1.0.0",
  "description": "Adds a Sync Rubric button to the Build Rubric section of Mercor Studio task pages. Loads a JSON file, updates/adds/deletes criteria by id, and writes the synced ids back to the file.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Mercor Studio — Rubric Sync",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://studio.mercor.com/annotator/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
